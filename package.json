{
  "name": "ai2wallet",
  "version": "0.0.2",
  "description": "CLI tool to scaffold a full ready project on top of ai2wallet SDK",
  "main": "index.ts",
  "type": "module",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeanlouis-dev/ai2wallet-cli"
  },
  "scripts": {
