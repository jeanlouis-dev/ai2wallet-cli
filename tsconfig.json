{
  "compilerOptions": {
      "target": "ES2017",
      "allowJs": true,
      "skipLibCheck": true,
      "module": "esnext",
      "moduleResolution": "bundler",
      "outDir": "dist",
      "strict": true,
      "esModuleInterop": true,
      "strictNullChecks": true,
      "declaration": true,
      "isolatedModules": true,
      "noImplicitAny": true,
      "noEmit": true,
      "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "tsup.config.ts"],
  "exclude": ["node_modules","dist"]
}
